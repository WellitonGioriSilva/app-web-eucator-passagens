
<% const filters = { cidadeOrigem: undefined, cidadeDestino: undefined, dataIda: undefined, dataVolta: undefined, tripTipo: undefined }; %>
<% const homeCities = typeof cities !== 'undefined' ? cities : []; %>
<% const homeTrips = typeof trips !== 'undefined' ? trips : []; %>
<section class="trips-hero">
    <div class="container trips-hero__wrap">
        <form class="trips-hero__card" action="/trips" method="GET">
            <h3 class="trips-hero__card-title">Viaje com a gente!</h3>

            <div class="trips-field">
              <span class="trips-field__icon"><i class="fa-solid fa-location-crosshairs"></i></span>
              <select
                name="cidadeOrigem"
                aria-label="Origem"
              >
                <option value="">De onde você vai sair?</option>
                <% homeCities.forEach(city => { %>
                  <option value="<%= city.id %>" <%= String(filters.cidadeOrigem || '') === String(city.id) ? 'selected' : '' %>>
                    <%= city.nome %> - <%= city.uf %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="trips-field trips-field--swap">
              <span class="trips-field__icon"><i class="fa-solid fa-location-dot"></i></span>
               <select
                name="cidadeDestino"
                aria-label="Destino"
              >
                <option value="">Para onde você vai?</option>
                <% homeCities.forEach(city => { %>
                  <option value="<%= city.id %>" <%= String(filters.cidadeDestino || '') === String(city.id) ? 'selected' : '' %>>
                    <%= city.nome %> - <%= city.uf %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="trips-options">
                <label>
                  <input type="radio" name="tripTipo" value="I"
                    <%= !filters.tripTipo || filters.tripTipo === 'I' ? 'checked' : '' %>>
                  Somente ida
                </label>

                <label>
                  <input type="radio" name="tripTipo" value="IV"
                    <%= filters.tripTipo === 'IV' ? 'checked' : '' %>>
                  Ida e volta
                </label>
            </div>

            <div class="trips-dates">
                <label>
                    <span>Data da ida</span>
                    <input type="date" name="dataIda" 
                    value="<%= filters.dataIda || '' %>"
                    aria-label="Data da ida">
                </label>
                <label>
                    <span>Data da volta</span>
                    <input type="date" name="dataVolta" 
                    value="<%= filters.dataVolta || '' %>"
                    aria-label="Data da volta">
                </label>
                <!-- <label>
                    <span>Data da volta</span>
                    <input type="date" aria-label="Data da volta">
                </label> -->
            </div>

            <div class="trips-checks">
                <!-- <label><input type="checkbox"> Inserir cupom</label>
                <label><input type="checkbox"> Comprar com pontos</label> -->
            </div>

            <button class="trips-cta" type="submit">Pesquisar viagens</button>
        </form>

        <div class="trips-hero__content">

        </div>

        <div class="trips-hero__image">
        </div>
    </div>
</section>

<section class="container trips-list">
  <h2 class="trips-list__title">As melhores ofertas para você</h2>

  <div class="trips-list__carousel-wrapper">
    <button class="trips-list__arrow trips-list__arrow--prev" onclick="slideCarousel(-1)">&#8249;</button>

    <div class="trips-list__track-container">
      <ul class="trips-list__track" id="tripsTrack">
        <% if (homeTrips.length) { %>
          <% homeTrips.forEach(trip => { %>
            <li class="trips-list__card">
              <div class="trips-list__card-bg" style="background-image: url('<%= trip.urlImagem || '/img/default-city.jpg' %>')"></div>
              <div class="trips-list__card-overlay"></div>
              <div class="trips-list__card-content">
                <p class="trips-list__card-origin" style="margin-bottom: 15px;">De <strong><%= trip.route.cidadeOrigem.nome %> - <%= trip.route.cidadeOrigem.uf %></strong></p>
                <p class="trips-list__card-destination">Para <strong><%= trip.route.cidadeDestino.nome %> - <%= trip.route.cidadeDestino.uf %></strong></p>
                <% if (trip.activePromotion) { %>
                  <p class="trips-list__card-old-price"><%= currencyFormat(trip.valor) %></p>
                <% } %>
                <p class="trips-list__card-from">Por apenas</p>
                <p class="trips-list__card-price"><%= currencyFormat(trip.promotionalValue ?? trip.valor) %></p>
                <% if (trip.discount) { %>
                  <span class="trips-list__card-badge"><%= trip.discount %>% OFF</span>
                <% } %>
                <a href="/trips/<%= trip.id %>/seats" class="trips-list__card-cta">Comprar</a>
              </div>
            </li>
          <% }) %>
        <% } else { %>
          <p class="trips-list__empty">Nenhuma viagem encontrada.</p>
        <% } %>
      </ul>
    </div>

    <button class="trips-list__arrow trips-list__arrow--next" onclick="slideCarousel(1)">&#8250;</button>
  </div>

  <div class="trips-list__footer">
    <a href="/ofertas" class="trips-list__more-btn">Conferir mais ofertas</a>
  </div>
</section>

