<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
	<meta name="author" content="Untree.co">
	<link rel="shortcut icon" href="/favicon.png">

	<meta name="description" content="" />
	<meta name="keywords" content="bootstrap, bootstrap4" />

	<!-- Bootstrap CSS -->
	<link href="/css/bootstrap.min.css" rel="stylesheet">
	<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
	<link href="/css/tiny-slider.css" rel="stylesheet">
	<link href="/css/style.css" rel="stylesheet">
	<title>Eucator - Cadastro</title>
	<link rel="icon" type="image/png" href="/images/favicon.png">

	<style>

	</style>
</head>
	<body>
		<form action="/client/create" method="POST" class="min-vh-100 d-flex flex-column align-items-center justify-content-center">
			<div class="container w-50 p-5 border rounded shadow bg-white d-flex flex-column gap-3">
				<label class="h2 text-center">Finalize o cadastro</label>
				<input type="hidden" id="jwt" name="token">
				<div class="form-group w-100">
					<label for="nome">Nome:</label>
					<input type="text" class="form-control w-100" id="nome" name="nome" required>
				</div>
				<div class="form-group w-100">
					<label for="cpf">Cpf:</label>
					<input type="text" class="form-control w-100" id="cpf" name="cpf" required>
				</div>
				<div class="form-group w-100">
					<label for="telefone">Telefone:</label>
					<input type="text" class="form-control w-100" id="telefone" name="telefone" required minlength="15" maxlength="15">
				</div>
				<div class="row g-3">
					<div class="col-md-4"><label for="cep">CEP:</label><input type="text" class="form-control" id="cep" name="cep" required minlength="8" maxlength="8"></div>
					<div class="col-md-8"><label for="logradouro">Logradouro:</label><input type="text" class="form-control" id="logradouro" name="logradouro" required maxlength="150"></div>
					<div class="col-md-4"><label for="numero">Numero:</label><input type="text" class="form-control" id="numero" name="numero" required maxlength="20"></div>
					<div class="col-md-8"><label for="complemento">Complemento:</label><input type="text" class="form-control" id="complemento" name="complemento" maxlength="100"></div>
					<div class="col-md-5"><label for="bairro">Bairro:</label><input type="text" class="form-control" id="bairro" name="bairro" required maxlength="100"></div>
					<div class="col-md-5"><label for="cidade">Cidade:</label><input type="text" class="form-control" id="cidade" name="cidade" required maxlength="100"></div>
					<div class="col-md-2"><label for="estado">UF:</label><input type="text" class="form-control text-uppercase" id="estado" name="estado" required minlength="2" maxlength="2"></div>
				</div>
				<button type="submit" class="btn btn-primary align-self-center mt-4 w-100">Cadastrar</button>
			</div>
			<% if (error) { %>
				<div class="alert alert-danger mt-3 w-25 align-self-center" role="alert">
					<%= error %>
				</div>
			<% } %>
		</form>

		<script src="/js/bootstrap.bundle.min.js"></script>
		<script src="/js/tiny-slider.js"></script>
		<script src="/js/custom.js"></script>
		<script>
			(function() {
				var token = localStorage.getItem('jwt');
				var input = document.getElementById('jwt');
				if (input && token) {
					input.value = token;
				}
			})();
		</script>
	</body>

</html>
