<section class="profile-page">
  <% const profileTickets = typeof tickets !== 'undefined' ? tickets : []; %>
  <div class="container profile-page__wrap">
    <div class="profile-page__header">
      <div>
        <p class="profile-page__subtitle">Minha conta</p>
        <h1 class="profile-page__title">Perfil do usuario</h1>
      </div>

      <% if (!client) { %>
        <a href="/client" class="profile-page__action">Completar cadastro</a>
      <% } %>
    </div>

    <% if (client) { %>
      <% if (typeof query !== 'undefined' && query.updated) { %>
        <p class="profile-form__success">Dados atualizados com sucesso.</p>
      <% } %>

      <form action="/user/profile" method="post" class="profile-account-form">
        <div class="profile-page__content">
          <section class="profile-panel profile-panel--wide profile-panel--personal">
            <div class="profile-panel__heading">
              <i class="fa-solid fa-user"></i>
              <h2>Dados pessoais</h2>
            </div>
            <div class="profile-form profile-form--personal">
              <label><span>Nome</span><input name="nome" value="<%= client.nome %>" required minlength="2"></label>
              <label><span>E-mail</span><input type="email" name="email" value="<%= user.email %>" required></label>
              <label><span>CPF</span><input name="cpf" value="<%= client.cpf %>" required minlength="14" maxlength="14"></label>
              <label><span>Telefone</span><input name="telefone" value="<%= client.telefone %>" required minlength="15" maxlength="15"></label>
            </div>
          </section>

          <section class="profile-panel profile-panel--wide profile-panel--address">
            <div class="profile-panel__heading">
              <i class="fa-solid fa-location-dot"></i>
              <h2>Endereco</h2>
            </div>
            <div class="profile-form profile-form--address">
              <label class="profile-form__field--cep"><span>CEP</span><input name="cep" value="<%= client.cep || '' %>" required minlength="8" maxlength="8"></label>
              <label class="profile-form__field--city"><span>Cidade</span><input name="cidade" value="<%= client.cidade || '' %>" required maxlength="100"></label>
              <label class="profile-form__field--state"><span>UF</span><input name="estado" value="<%= client.estado || '' %>" required minlength="2" maxlength="2" class="text-uppercase"></label>
              <label class="profile-form__field--wide"><span>Logradouro</span><input name="logradouro" value="<%= client.logradouro || '' %>" required maxlength="150"></label>
              <label class="profile-form__field--number"><span>Numero</span><input name="numero" value="<%= client.numero || '' %>" required maxlength="20"></label>
              <label class="profile-form__field--complement"><span>Complemento</span><input name="complemento" value="<%= client.complemento || '' %>" maxlength="100"></label>
              <label class="profile-form__field--wide"><span>Bairro</span><input name="bairro" value="<%= client.bairro || '' %>" required maxlength="100"></label>
            </div>
          </section>
        </div>

        <div class="profile-account-form__actions">
          <button type="submit"><i class="fa-solid fa-floppy-disk"></i> Salvar alteracoes</button>
        </div>
      </form>
    <% } else { %>
      <section class="profile-panel profile-panel--wide">
        <div class="profile-empty">
          <i class="fa-solid fa-id-card"></i>
          <p>Complete seus dados de cliente para comprar passagens.</p>
          <a href="/client" class="profile-empty__button">Completar cadastro</a>
        </div>
      </section>
    <% } %>

    <section class="profile-panel profile-panel--wide">
      <h2>Minhas compras</h2>

      <% if (profileTickets.length) { %>
        <div class="profile-tickets">
          <% profileTickets.forEach(ticket => { %>
            <% const payment = ticket.sale && ticket.sale.payments && ticket.sale.payments.length ? ticket.sale.payments[0] : null; %>
            <article class="profile-ticket">
              <div class="profile-ticket__route">
                <strong>
                  <%= ticket.trip.route.cidadeOrigem.nome %> - <%= ticket.trip.route.cidadeOrigem.uf %>
                  para
                  <%= ticket.trip.route.cidadeDestino.nome %> - <%= ticket.trip.route.cidadeDestino.uf %>
                </strong>
                <span>Saida <%= dateFormatDayMonth(ticket.trip.dtHoraSaida) %> as <%= timeFormat(ticket.trip.dtHoraSaida) %></span>
              </div>

              <div class="profile-ticket__meta">
                <span>Poltrona <strong><%= ticket.seat.numero %></strong></span>
                <span>Passagem <strong>#<%= ticket.id %></strong></span>
                <span>Status <strong><%= ticket.status %></strong></span>
                <span>Pagamento <strong><%= payment ? payment.status : 'pendente' %></strong></span>
              </div>

              <a href="/user/tickets/<%= ticket.id %>/pdf" target="_blank" class="profile-ticket__print">
                <i class="fa-solid fa-print"></i>
                Imprimir
              </a>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="profile-empty">
          <i class="fa-solid fa-ticket"></i>
          <p>Nenhuma compra encontrada.</p>
        </div>
      <% } %>
    </section>
  </div>
</section>
