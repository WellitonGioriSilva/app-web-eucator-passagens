<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
	<meta name="author" content="Untree.co">
	<link rel="shortcut icon" href="/favicon.png">

	<meta name="description" content="" />
	<meta name="keywords" content="bootstrap, bootstrap4" />

	<!-- Bootstrap CSS -->
	<link href="/css/bootstrap.min.css" rel="stylesheet">
	<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
	<link href="/css/tiny-slider.css" rel="stylesheet">
	<link href="/css/style.css" rel="stylesheet">
	<title>Eucator - Cadastro</title>

	<style>

	</style>
</head>
	<body>
		<form action="/user/create" method="POST" class="min-vh-100 d-flex flex-column align-items-center justify-content-center">
			<div class="container w-25 p-5 border rounded shadow bg-white d-flex flex-column gap-3">
				<label class="h2 text-center">Cadastro</label>
				<div class="form-group w-100">
					<label for="email">Email:</label>
					<input type="email" class="form-control w-100" id="email" name="email" required>
				</div>
				<div class="form-group w-100">
					<label for="password">Senha:</label>
					<input type="password" class="form-control w-100" id="password" name="password" required>
				</div>
				<div class="form-group w-100">
					<label for="confirmPassword">Confirmar Senha:</label>
					<input type="password" class="form-control w-100" id="confirmPassword" name="confirmPassword" required>
				</div>
				<button type="submit" class="btn btn-primary align-self-center mt-4 w-100">Cadastrar</button>
				<a href="/auth" class="align-self-center mt-2">Já possui conta? Faça login.</a>
			</div>
			<% if (error) { %>
				<div class="alert alert-danger mt-3 w-25 align-self-center" role="alert">
					<%= error %>
				</div>
			<% } %>
		</form>

		<script src="/js/bootstrap.bundle.min.js"></script>
		<script src="/js/tiny-slider.js"></script>
		<script src="/js/custom.js"></script>
	</body>

</html>
