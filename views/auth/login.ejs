<!doctype html>
<html lang="pt-BR">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
	<meta name="author" content="Untree.co">
	<link rel="shortcut icon" href="/favicon.png">

	<meta name="description" content="" />
	<meta name="keywords" content="bootstrap, bootstrap4" />

	<link href="/css/bootstrap.min.css" rel="stylesheet">
	<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
	<link href="/css/tiny-slider.css" rel="stylesheet">
	<link href="/css/style.css" rel="stylesheet">
	<title>Eucator - Login</title>
</head>
	<body>
		<form action="/auth/login" method="POST" class="auth-page">
			<div class="auth-card d-flex flex-column gap-3">
				<label class="auth-card__title">Entrar</label>
				<div class="form-group w-100">
					<label for="email">Email:</label>
					<input type="email" class="form-control w-100" id="email" name="email" required>
				</div>
				<div class="form-group w-100">
					<label for="password">Senha:</label>
					<input type="password" class="form-control w-100" id="password" name="password" required>
				</div>
				<button type="submit" class="btn btn-primary align-self-center mt-4 w-100">Entrar</button>
				<a href="/user/create" class="auth-card__link">Nao possui conta? Cadastre-se.</a>
			</div>

			<div id="login-error" class="alert alert-danger mt-3 auth-alert <%= error ? '' : 'd-none' %>" role="alert">
				<%= error || '' %>
			</div>
		</form>

		<script src="/js/bootstrap.bundle.min.js"></script>
		<script src="/js/tiny-slider.js"></script>
		<script src="/js/custom.js"></script>
		<script>
			(function() {
				var form = document.querySelector('form');
				var errorBox = document.getElementById('login-error');
				if (!form) return;

				form.addEventListener('submit', async function(event) {
					event.preventDefault();
					var formData = new FormData(form);
					var payload = Object.fromEntries(formData.entries());

					try {
						var response = await fetch('/auth/login', {
							method: 'POST',
							headers: {
								'Content-Type': 'application/json',
								'Accept': 'application/json',
								'X-Requested-With': 'XMLHttpRequest'
							},
							body: JSON.stringify(payload)
						});
						var result = await response.json();

						if (!response.ok || result.status !== 'success') {
							showError((result && result.message) ? result.message : 'Falha no login');
							return;
						}

						localStorage.setItem('jwt', result.data.token);
						localStorage.setItem('jwt_refresh', result.data.refreshToken);

						var hasClient = !!result.data.hasClient;
						window.location.href = hasClient ? '/' : '/client/';
					} catch (err) {
						showError('Falha no login');
					}
				});

				function showError(message) {
					if (!errorBox) return;
					errorBox.textContent = message;
					errorBox.classList.remove('d-none');
				}
			})();
		</script>
	</body>
</html>
